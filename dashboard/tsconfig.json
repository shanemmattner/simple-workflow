{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "paths": {
      "@/*": ["./client/src/*"]
    }
  },
  "include": ["server/**/*.ts", "client/src/**/*.ts", "client/src/**/*.vue"]
}
